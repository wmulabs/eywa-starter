# Copy to .env and fill in. The Makefile loads it for `make run`.
# Google AI Studio key (https://aistudio.google.com/apikey).
GEMINI_API_KEY=...

# HTTP server
PORT=8080

# Defaults match deployments/docker-compose.yaml — override only if you run infra elsewhere.
MONGO_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379
MONGO_DATABASE=eywa_starter
SERVICE_NAME=eywa-starter
ENVIRONMENT=lcl

# Reasoning loop
MAX_ITERATIONS=5

# Management/admin API. Optional: when set, mounts the token-protected admin routes
# (/api/v1/discovery, /chronicle, /analytics, /echoes, /app-tokens). Leave empty to disable them.
ADMIN_API_KEY=

# Require an app token on the event endpoint (needs ADMIN_API_KEY to mint tokens via /api/v1/app-tokens).
# Default false: events are open (webhook-style).
REQUIRE_EVENT_TOKEN=false
